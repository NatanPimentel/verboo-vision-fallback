# Configuração do plugin verboo-vision-fallback
# Copie este arquivo para .env e preencha com seus valores.
# O .env é carregado automaticamente pelo Node quando as variáveis estão no ambiente.
# Para o hook automático no Verboo Code, configure as opções na UI do plugin.

# Provedor de visão OpenAI-compatible (ex: OpenRouter, OpenAI, DeepSeek, etc.)
VISION_API_KEY=sk-or-v1-...
VISION_BASE_URL=https://openrouter.ai/api/v1
VISION_MODEL=openai/gpt-4o

# Opcional: timeout em milissegundos (máx. 55000)
# VISION_TIMEOUT_MS=30000
