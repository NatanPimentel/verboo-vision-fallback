{
  "description": "Descreve automaticamente imagens anexadas antes da resposta do modelo principal.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/image-hook.mjs\"",
            "timeout": 70
          }
        ]
      }
    ]
  }
}
